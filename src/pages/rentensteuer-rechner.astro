---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead
			title="Steuerrechner für Rentner — Wie viel Steuern auf die Rente? (kostenlos)"
			description="Kostenloser Steuerrechner für Rentner: Berechne in 60 Sekunden Besteuerungsanteil, Rentenfreibetrag und deine Einkommensteuer auf die Rente — Tarif 2025."
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<p class="label">Kostenlos & anonym</p>
				<h1>Steuerrechner für Rentner</h1>
				<p class="subtitle">
					In 60 Sekunden erfährst du, wie viel Einkommensteuer auf deine Rente anfällt — mit Besteuerungsanteil nach Renteneintrittsjahr, Rentenfreibetrag und Steuertarif 2025.
				</p>
			</div>

			<!-- Step 1: Input -->
			<div id="step-input" class="card">
				<h2>Deine Angaben</h2>

				<div class="field">
					<label for="eintritt-range">Jahr des Renteneintritts</label>
					<p class="field-hint">Bestimmt den Besteuerungsanteil deiner Rente (2005: 50 % … 2058: 100 %)</p>
					<div class="input-row">
						<input type="range" id="eintritt-range" min="2005" max="2058" value="2026" />
						<span class="input-display"><span id="eintritt-val">2026</span></span>
					</div>
				</div>

				<div class="field">
					<label for="rente-range">Monatliche Bruttorente</label>
					<p class="field-hint">Gesetzliche Rente vor Abzügen (steht im Rentenbescheid)</p>
					<div class="input-row">
						<input type="range" id="rente-range" min="500" max="4000" step="50" value="1600" />
						<span class="input-display"><span id="rente-val">1.600</span> €/Monat</span>
					</div>
				</div>

				<div class="field">
					<label for="weitere-range">Weitere steuerpflichtige Einkünfte pro Jahr</label>
					<p class="field-hint">z. B. Mieteinnahmen, Betriebsrente, Minijob zählt nicht</p>
					<div class="input-row">
						<input type="range" id="weitere-range" min="0" max="24000" step="500" value="0" />
						<span class="input-display"><span id="weitere-val">0</span> €/Jahr</span>
					</div>
				</div>

				<div class="field">
					<label class="checkbox-label">
						<input type="checkbox" id="splitting-check" />
						Verheiratet (Zusammenveranlagung / Splittingtarif)
					</label>
					<p class="field-hint">Dann bitte Rente und Einkünfte beider Partner zusammen eingeben</p>
				</div>

				<button id="calc-btn" class="btn-primary">Steuer auf die Rente berechnen</button>
			</div>

			<!-- Step 2: Results -->
			<div id="step-result" class="card hidden">
				<h2>Dein Ergebnis</h2>

				<div class="result-grid">
					<div class="result-box">
						<p class="result-label">Besteuerungsanteil deiner Rente</p>
						<p class="result-value" id="res-anteil">–</p>
						<p class="result-note">Abhängig vom Renteneintrittsjahr</p>
					</div>
					<div class="result-box">
						<p class="result-label">Rentenfreibetrag (lebenslang fix)</p>
						<p class="result-value" id="res-freibetrag">–</p>
						<p class="result-note">Dieser Teil der Jahresrente bleibt dauerhaft steuerfrei</p>
					</div>
					<div class="result-box">
						<p class="result-label">Zu versteuerndes Einkommen</p>
						<p class="result-value" id="res-zve">–</p>
						<p class="result-note">Nach Pauschalen und Vorsorgeaufwendungen (vereinfacht)</p>
					</div>
					<div class="result-box highlight">
						<p class="result-label">Einkommensteuer pro Jahr</p>
						<p class="result-value" id="res-steuer">–</p>
						<p class="result-note" id="res-steuer-monat">–</p>
					</div>
				</div>

				<div class="sparrate-box">
					<p class="sparrate-label">Effektive Steuerquote auf deine Rente</p>
					<p class="sparrate-value" id="res-quote">–</p>
					<p class="sparrate-note" id="res-erklaerung">–</p>
				</div>

				<div class="disclaimer-calc">
					Diese Berechnung ist eine vereinfachte Schätzung nach Einkommensteuertarif 2025 (§ 32a EStG, Grundfreibetrag 12.096 €) — keine Steuerberatung. Kirchensteuer, Kapitalerträge, außergewöhnliche Belastungen und individuelle KV/PV-Beiträge sind pauschaliert bzw. nicht berücksichtigt. Verbindliche Auskünfte gibt dein Finanzamt oder ein Steuerberater.
				</div>

				<div class="cta-box">
					<p class="cta-label">Nächster Schritt</p>
					<h3>Sorge dafür, dass deine Rente später reicht</h3>
					<p class="cta-sub">
						Hol dir die kostenlose Finanzcheck-Checkliste — 20 Fragen zu Liquidität, Versicherungen, Steuern, Altersvorsorge und Einkommen. Auch ideal, um sie gemeinsam mit den eigenen Eltern durchzugehen.
					</p>
					<form
						action="https://app.kit.com/forms/9299804/subscriptions"
						method="post"
						class="cta-form"
					>
						<input
							type="email"
							name="email_address"
							placeholder="deine@email.de"
							required
							aria-label="E-Mail-Adresse"
						/>
						<input type="hidden" name="fields[quelle]" value="rentensteuer-rechner" />
						<button type="submit" class="btn-primary">Checkliste per E-Mail erhalten</button>
					</form>
					<p class="cta-privacy">Kein Spam. Jederzeit abmeldbar.</p>

					<div class="or-divider">oder</div>
					<a href="/finanzcheck/" class="btn-secondary" target="_blank">Checkliste direkt öffnen →</a>

					<div class="call-cta">
						<p class="call-cta-text">Fragen zur Rente — für dich oder deine Eltern?</p>
						<a
							href="https://outlook.office.com/bookwithme/user/f7d184a8790c451390cda05ae8b3fb18@tecis.de/meetingtype/cdie9Hia-EulszcibmFVfQ2?bookingcode=d1927a5d-5856-470c-894c-a255316c0f36&anonymous&ismsaljsauthenabled&ep=mlink&utm_source=blog&utm_medium=rechner&utm_campaign=rentensteuer"
							class="btn-primary"
							target="_blank"
							rel="noopener"
						>15-Min-Kennenlernen buchen →</a>
						<p class="cta-privacy">Kostenlos & unverbindlich. Du wählst den Termin.</p>
					</div>
				</div>

				<button id="reset-btn" class="btn-ghost">← Neu berechnen</button>
			</div>

			<!-- SEO / Erklärung -->
			<section class="seo-section">
				<h2>So rechnet dieser Steuerrechner für Rentner</h2>
				<p>
					Die gesetzliche Rente ist nicht komplett steuerpflichtig: Je nach <strong>Renteneintrittsjahr</strong> gilt ein Besteuerungsanteil zwischen 50 % (Eintritt 2005) und 100 % (Eintritt ab 2058). Der steuerfreie Teil der ersten vollen Jahresrente wird als <strong>Rentenfreibetrag</strong> lebenslang festgeschrieben. Auf den steuerpflichtigen Teil — abzüglich Werbungskosten-Pauschale (102 €), Sonderausgaben-Pauschale (36 €) und pauschalierten Kranken- und Pflegeversicherungsbeiträgen — wird der normale Einkommensteuertarif angewendet.
				</p>
				<p>
					Die Hintergründe im Detail: <a href="/blog/rentenbesteuerung-wie-viel-steuern-auf-rente/">Wie viel Steuern zahlt man auf die Rente?</a> · <a href="/blog/rentenfreibetrag-was-bleibt-steuerfrei/">Rentenfreibetrag erklärt</a> · <a href="/blog/rente-fruehzeitig-abschlaege/">Früher in Rente: Abschläge</a>
				</p>

				<h2>Häufige Fragen</h2>
				<details>
					<summary>Ab welcher Rente muss man Steuern zahlen?</summary>
					<p>Steuern fallen an, sobald das zu versteuernde Einkommen über dem Grundfreibetrag liegt (2025: 12.096 € für Alleinstehende, 24.192 € bei Zusammenveranlagung). Wer 2025 in Rente geht, bleibt mit einer Bruttorente bis etwa 1.300 €/Monat ohne weitere Einkünfte meist steuerfrei — die genaue Grenze hängt vom Eintrittsjahr und den absetzbaren Vorsorgeaufwendungen ab.</p>
				</details>
				<details>
					<summary>Muss ich als Rentner eine Steuererklärung abgeben?</summary>
					<p>Eine Pflicht besteht, wenn das zu versteuernde Einkommen über dem Grundfreibetrag liegt. Das Finanzamt erhält die Rentenbezugsmitteilung automatisch von der Rentenversicherung — wer abgabepflichtig ist und nichts einreicht, wird in der Regel angeschrieben. Im Zweifel: Erklärung abgeben; oft ergibt sich durch absetzbare Kosten sogar eine Erstattung.</p>
				</details>
				<details>
					<summary>Steigt mein Besteuerungsanteil mit jeder Rentenerhöhung?</summary>
					<p>Der Prozentsatz bleibt fix — aber der Rentenfreibetrag ist ein fester Euro-Betrag. Jede Rentenerhöhung ist dadurch zu 100 % steuerpflichtig. Deshalb rutschen langjährige Rentner mit den jährlichen Anpassungen schrittweise in die Steuerpflicht, obwohl sich „ihr Prozentsatz" nie ändert.</p>
				</details>
				<details>
					<summary>Was ist mit Kranken- und Pflegeversicherung?</summary>
					<p>KV- und PV-Beiträge werden direkt von der Bruttorente abgezogen (rund 11–12 %), sind aber als Vorsorgeaufwendungen absetzbar — dieser Rechner berücksichtigt das pauschal. Die Beiträge selbst sind keine Steuer: Netto von der Rente bleibt Bruttorente minus KV/PV minus Einkommensteuer.</p>
				</details>

				<p class="weitere-rechner">Weitere Rechner: <a href="/rentenluecke-rechner/">Rentenlücken-Rechner</a> · <a href="/sparplan-rechner/">Sparplan-Rechner</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	const eintrittRange = document.getElementById('eintritt-range') as HTMLInputElement;
	const renteRange = document.getElementById('rente-range') as HTMLInputElement;
	const weitereRange = document.getElementById('weitere-range') as HTMLInputElement;
	const splittingCheck = document.getElementById('splitting-check') as HTMLInputElement;
	const eintrittVal = document.getElementById('eintritt-val')!;
	const renteVal = document.getElementById('rente-val')!;
	const weitereVal = document.getElementById('weitere-val')!;
	const calcBtn = document.getElementById('calc-btn')!;
	const resetBtn = document.getElementById('reset-btn')!;
	const stepInput = document.getElementById('step-input')!;
	const stepResult = document.getElementById('step-result')!;

	function fmt(n: number) {
		return Math.round(n).toLocaleString('de-DE');
	}

	eintrittRange.addEventListener('input', () => { eintrittVal.textContent = eintrittRange.value; });
	renteRange.addEventListener('input', () => { renteVal.textContent = fmt(Number(renteRange.value)); });
	weitereRange.addEventListener('input', () => { weitereVal.textContent = fmt(Number(weitereRange.value)); });

	// Besteuerungsanteil nach § 22 EStG (inkl. Wachstumschancengesetz: +0,5 %p/Jahr ab 2023, 100 % ab 2058)
	function besteuerungsanteil(jahr: number): number {
		if (jahr <= 2005) return 50;
		if (jahr <= 2020) return 50 + 2 * (jahr - 2005);
		if (jahr <= 2022) return 80 + 1 * (jahr - 2020);
		if (jahr <= 2057) return 82 + 0.5 * (jahr - 2022);
		return 100;
	}

	// Einkommensteuer-Grundtarif 2025 (§ 32a EStG)
	function est2025(zvE: number): number {
		const x = Math.floor(zvE);
		if (x <= 12096) return 0;
		if (x <= 17443) {
			const y = (x - 12096) / 10000;
			return Math.floor((932.3 * y + 1400) * y);
		}
		if (x <= 68480) {
			const z = (x - 17443) / 10000;
			return Math.floor((176.64 * z + 2397) * z + 1015.13);
		}
		if (x <= 277825) return Math.floor(0.42 * x - 10911.92);
		return Math.floor(0.45 * x - 19246.67);
	}

	calcBtn.addEventListener('click', () => {
		const eintritt = Number(eintrittRange.value);
		const renteMonat = Number(renteRange.value);
		const weitere = Number(weitereRange.value);
		const splitting = splittingCheck.checked;

		const jahresrente = renteMonat * 12;
		const anteil = besteuerungsanteil(eintritt);
		const freibetrag = Math.round(jahresrente * (1 - anteil / 100));
		const steuerpflichtigeRente = jahresrente - freibetrag;

		// Pauschalen + Vorsorgeaufwendungen (KV/PV der Rentner, vereinfacht 12 % der Bruttorente)
		const vorsorge = Math.round(jahresrente * 0.12);
		const zvE = Math.max(0, steuerpflichtigeRente + weitere - 102 - 36 - vorsorge);

		const steuer = splitting ? 2 * est2025(zvE / 2) : est2025(zvE);
		const quote = jahresrente > 0 ? (steuer / jahresrente) * 100 : 0;

		document.getElementById('res-anteil')!.textContent = anteil.toLocaleString('de-DE') + ' %';
		document.getElementById('res-freibetrag')!.textContent = fmt(freibetrag) + ' €/Jahr';
		document.getElementById('res-zve')!.textContent = fmt(zvE) + ' €';
		document.getElementById('res-steuer')!.textContent = steuer > 0 ? fmt(steuer) + ' €' : '0 € 🎉';
		document.getElementById('res-steuer-monat')!.textContent = steuer > 0
			? 'entspricht ' + fmt(steuer / 12) + ' €/Monat'
			: 'Dein Einkommen liegt unter dem Grundfreibetrag';
		document.getElementById('res-quote')!.textContent = quote.toLocaleString('de-DE', { maximumFractionDigits: 1 }) + ' %';
		document.getElementById('res-erklaerung')!.textContent = steuer > 0
			? 'Anteil der Einkommensteuer an deiner Brutto-Jahresrente von ' + fmt(jahresrente) + ' €'
			: 'Auf deine Rente fällt nach dieser Schätzung keine Einkommensteuer an';

		stepInput.classList.add('hidden');
		stepResult.classList.remove('hidden');
		stepResult.scrollIntoView({ behavior: 'smooth', block: 'start' });
	});

	resetBtn.addEventListener('click', () => {
		stepResult.classList.add('hidden');
		stepInput.classList.remove('hidden');
		stepInput.scrollIntoView({ behavior: 'smooth', block: 'start' });
	});
</script>

<style>
