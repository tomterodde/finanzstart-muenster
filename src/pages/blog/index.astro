---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = ['Alle', 'Grundlagen', 'Versicherungen', 'Einkommenssicherung', 'Vermögensaufbau', 'Altersvorsorge'];

const categorySlugMap: Record<string, string> = {
	Grundlagen: 'grundlagen',
	Versicherungen: 'versicherungen',
	Einkommenssicherung: 'einkommenssicherung',
	Vermögensaufbau: 'vermoegensaufbau',
	Altersvorsorge: 'altersvorsorge',
};
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={`Alle Artikel – ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="filter-bar">
				{categories.map((cat) => (
					cat === 'Alle' ? (
						<button class="filter-btn active" data-category="Alle">{cat}</button>
					) : (
						<a
							class="filter-btn"
							href={`/blog/kategorie/${categorySlugMap[cat]}/`}
						>{cat}</a>
					)
				))}
			</div>

			<ul id="post-list">
				{posts.map((post) => (
					<li data-category={post.data.category ?? 'Grundlagen'}>
						<a href={`/blog/${post.id}/`}>
							<div class="post-meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.category && (
									<a
										class="category-badge"
										href={`/blog/kategorie/${categorySlugMap[post.data.category]}/`}
										onclick="event.stopPropagation()"
									>{post.data.category}</a>
								)}
							</div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>

			<p id="no-results" class="no-results" style="display:none">
				Keine Artikel in dieser Kategorie.
			</p>
		</main>
		<Footer />
	</body>
</html>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const items = document.querySelectorAll<HTMLLIElement>('#post-list li');
	const noResults = document.getElementById('no-results')!;

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			buttons.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');

			const selected = btn.dataset.category!;
			let visible = 0;

			items.forEach((item) => {
				const match = selected === 'Alle' || item.dataset.category === selected;
				item.style.display = match ? '' : 'none';
				if (match) visible++;
			});

			noResults.style.display = visible === 0 ? 'block' : 'none';
		});
	});
</script>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 2.5em 1.5em 5em;
	}
	.filter-bar {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-bottom: 2em;
	}
	.filter-btn {
		display: inline-block;
		padding: 0.45em 1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		background: white;
		color: rgb(var(--gray-dark));
		font-size: 0.875em;
		font-family: inherit;
		cursor: pointer;
		text-decoration: none;
		transition: background 0.15s, color 0.15s, border-color 0.15s;
	}
	.filter-btn:hover {
		background: var(--accent-light);
		border-color: var(--accent);
		color: var(--accent);
	}
	.filter-btn.active {
		background: var(--accent);
		border-color: var(--accent);
		color: white;
		font-weight: 600;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
		background: rgb(var(--gray-light));
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		overflow: hidden;
	}
	li a {
		display: block;
		padding: 1.5em 1.8em;
		text-decoration: none;
		background: white;
		transition: background 0.15s;
	}
	li a:hover {
		background: var(--accent-light);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin-bottom: 0.4em;
	}
	.category-badge {
		display: inline-block;
		padding: 0.15em 0.6em;
		background: var(--accent-light);
		color: var(--accent);
		border-radius: 999px;
		font-size: 0.85em;
		font-weight: 600;
		line-height: 1.4;
		text-decoration: none;
	}
	.category-badge:hover {
		background: var(--accent);
		color: white;
	}
	li h3 {
		font-size: 1.15em;
		color: rgb(var(--black));
		margin: 0 0 0.4em;
	}
	li p {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: 0;
		line-height: 1.5;
	}
	.no-results {
		text-align: center;
		color: rgb(var(--gray));
		padding: 3em 0;
		font-size: 0.95em;
	}
</style>
