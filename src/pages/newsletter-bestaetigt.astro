---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead
			title="Newsletter bestätigt – Finanzstart Münster"
			description="Deine Newsletter-Anmeldung wurde erfolgreich bestätigt."
		/>
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body>
		<Header />
		<main>
			<div class="confirm-wrapper">
				<div class="icon">✓</div>
				<h1>Du bist dabei.</h1>
				<p class="lead">
					Deine Anmeldung ist bestätigt. Du bekommst neue Artikel direkt in dein Postfach —
					keine Werbung, kein Spam, nur relevante Finanzthemen für Berufseinsteiger in Münster.
				</p>
				<div class="finanzcheck-box">
					<div class="finanzcheck-icon">📋</div>
					<h2>Dein nächster Schritt</h2>
					<p>Hol dir jetzt die kostenlose Finanzcheck-Checkliste — 20 Fragen in 5 Bereichen, die du dir stellen solltest.</p>
					<a href="/finanzcheck/" class="btn-primary">Zur Finanzcheck-Checkliste →</a>
				</div>
				<div class="next-steps">
					<h2>Was dich erwartet</h2>
					<ul>
						<li>Neue Artikel zu ETF, Rente, Steuern und Einkommenssicherung</li>
						<li>Konkrete Zahlen statt vager Ratschläge</li>
						<li>1–2 E-Mails pro Woche — nicht mehr</li>
					</ul>
				</div>
				<div class="cta-group">
					<a href="/blog/" class="btn-primary">Alle Artikel lesen</a>
					<a href="/" class="btn-secondary">Zur Startseite</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 4em 1.5em 6em;
	}

	.confirm-wrapper {
		max-width: 560px;
		margin: 0 auto;
		text-align: center;
	}

	.icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 72px;
		height: 72px;
		background: var(--accent-light);
		color: var(--accent);
		border-radius: 50%;
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.2em;
		margin: 0 0 0.75em;
		color: rgb(var(--black));
	}

	.lead {
		font-size: 1.1em;
		color: rgb(var(--gray-dark));
		line-height: 1.7;
		margin: 0 0 2.5em;
	}

	.finanzcheck-box {
		background: var(--accent);
		color: white;
		border-radius: 12px;
		padding: 1.75em 2em;
		margin-bottom: 1.5em;
	}

	.finanzcheck-icon {
		font-size: 2em;
		margin-bottom: 0.5em;
	}

	.finanzcheck-box h2 {
		font-size: 1.1em;
		font-weight: 700;
		color: white;
		margin: 0 0 0.4em;
	}

	.finanzcheck-box p {
		font-size: 0.9em;
		color: rgba(255, 255, 255, 0.9);
		margin: 0 0 1.2em;
		line-height: 1.5;
	}

	.finanzcheck-box .btn-primary {
		background: white;
		color: var(--accent);
	}

	.finanzcheck-box .btn-primary:hover {
		background: rgba(255, 255, 255, 0.9);
	}

	.next-steps {
		background: var(--accent-light);
		border-radius: 12px;
		padding: 1.5em 2em;
		text-align: left;
		margin-bottom: 2.5em;
	}

	.next-steps h2 {
		font-size: 1em;
		font-weight: 700;
		color: var(--accent-dark);
		margin: 0 0 0.75em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.next-steps ul {
		margin: 0;
		padding: 0 0 0 1.25em;
		color: rgb(var(--gray-dark));
		line-height: 1.8;
	}

	.next-steps li {
		margin-bottom: 0.25em;
	}

	.cta-group {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-primary {
		display: inline-block;
		background: var(--accent);
		color: #fff;
		padding: 0.75em 1.75em;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		font-size: 0.95em;
		transition: background 0.15s;
	}

	.btn-primary:hover {
		background: var(--accent-dark);
	}

	.btn-secondary {
		display: inline-block;
		background: transparent;
		color: var(--accent);
		padding: 0.75em 1.75em;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		font-size: 0.95em;
		border: 2px solid var(--accent);
		transition: background 0.15s, color 0.15s;
	}

	.btn-secondary:hover {
		background: var(--accent-light);
	}

	@media (max-width: 480px) {
		h1 {
			font-size: 1.75em;
		}

		.next-steps {
			padding: 1.25em 1.25em;
		}

		.cta-group {
			flex-direction: column;
			align-items: center;
		}

		.btn-primary,
		.btn-secondary {
			width: 100%;
			text-align: center;
		}
	}
</style>
