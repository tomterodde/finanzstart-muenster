---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
	<section class="related" aria-label="Verwandte Artikel">
		<h2>Verwandte Artikel</h2>
		<ul>
			{posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`}>
						{post.data.category && <span class="category">{post.data.category}</span>}
						<h3>{post.data.title}</h3>
						<p class="desc">{post.data.description}</p>
						<span class="date"><FormattedDate date={post.data.pubDate} /></span>
					</a>
				</li>
			))}
		</ul>
	</section>
)}

<style>
	.related {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.related h2 {
		font-size: 1.3em;
		margin: 0 0 1em;
	}
	.related ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75em;
	}
	.related li a {
		display: block;
		padding: 1em 1.2em;
		text-decoration: none;
		background: rgba(var(--gray-light), 0.4);
		border-radius: 8px;
		transition: background 0.15s;
		color: rgb(var(--black));
	}
	.related li a:hover {
		background: rgba(var(--gray-light), 0.8);
	}
	.related .category {
		display: inline-block;
		font-size: 0.7em;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgb(var(--gray-dark));
		margin-bottom: 0.3em;
		font-weight: 600;
	}
	.related h3 {
		font-size: 1.05em;
		margin: 0 0 0.3em;
		line-height: 1.3;
	}
	.related .desc {
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
		margin: 0 0 0.4em;
		line-height: 1.45;
	}
	.related .date {
		font-size: 0.78em;
		color: rgb(var(--gray));
	}
</style>
