---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="footer-brand">Finanzstart Münster</p>
		<p class="footer-disclaimer">
			Kein Ersatz für individuelle Beratung · Keine Anlageberatung nach §34f · Alle Inhalte dienen der allgemeinen Finanzbildung.
		</p>
		<p class="footer-copy">&copy; {today.getFullYear()} Tom Terodde · Münster</p>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1.5em;
		background: rgb(var(--gray-dark));
		color: rgb(var(--gray-light));
	}
	.footer-inner {
		max-width: 860px;
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
	}
	.footer-brand {
		font-weight: 700;
		font-size: 1.1em;
		color: white;
		margin: 0;
	}
	.footer-disclaimer {
		font-size: 0.8em;
		color: rgba(229, 233, 240, 0.7);
		margin: 0;
		max-width: 560px;
		margin: 0 auto;
		line-height: 1.5;
	}
	.footer-copy {
		font-size: 0.8em;
		color: rgba(229, 233, 240, 0.5);
		margin: 0;
	}
</style>
