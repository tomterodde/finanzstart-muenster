---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="footer-brand">Finanzstart Münster</p>
		<p class="footer-disclaimer">
			Kein Ersatz für individuelle Beratung · Keine Anlageberatung nach §34f · Alle Inhalte dienen der allgemeinen Finanzbildung.
		</p>
		<nav class="footer-links">
			<a href="/impressum">Impressum</a>
			<span>·</span>
			<a href="/datenschutz">Datenschutz</a>
		</nav>
		<p class="footer-copy">&copy; {today.getFullYear()} Tom Terodde · Münster</p>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1.5em;
		background: rgb(var(--gray-dark));
		color: rgb(var(--gray-light));
	}
	.footer-inner {
		max-width: 860px;
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
	}
	.footer-brand {
		font-weight: 700;
		font-size: 1.1em;
		color: white;
		margin: 0;
	}
	.footer-disclaimer {
		font-size: 0.8em;
		color: rgba(229, 233, 240, 0.9);
		margin: 0;
		max-width: 560px;
		margin: 0 auto;
		line-height: 1.5;
	}
	.footer-links {
		display: flex;
		gap: 0.5em;
		align-items: center;
		justify-content: center;
		font-size: 0.8em;
	}
	.footer-links a {
		color: rgba(229, 233, 240, 0.85);
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-links a:hover {
		color: white;
	}
	.footer-links span {
		color: rgba(229, 233, 240, 0.6);
	}
	.footer-copy {
		font-size: 0.8em;
		color: rgba(229, 233, 240, 0.75);
		margin: 0;
	}
</style>
